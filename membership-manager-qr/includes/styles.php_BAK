        text-align: center;
        cursor: pointer;
        font-weight: bold;
        border: none;
        background: none;
        transition: all 0.3s;
    }
    
    .mmgr-tab.active {
        background: white;
        color: #9b51e0;
        border-bottom: 3px solid #9b51e0;
    }
    
    .mmgr-empty-state {
