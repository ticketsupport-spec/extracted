        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        border: 2px solid #9b51e0;
        overflow: hidden;
    }
    
    .mmgr-conversation-item {
        padding: 15px;
        border-bottom: 1px solid #e0e0e0;
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    
    .mmgr-conversation-item:hover {
        background: #f9f9f9;
