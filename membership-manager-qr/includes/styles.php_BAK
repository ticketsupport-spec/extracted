    }
    
    .mmgr-message-textarea {
        flex: 1;
        padding: 12px;
        border: 2px solid #ddd;
        border-radius: 8px;
        resize: none;
        font-family: inherit;
        font-size: 15px;
    }
    
    .mmgr-send-btn {
        background: #9b51e0;
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        transition: all 0.3s;
    }
    
    .mmgr-send-btn:hover {
        background: #ce00ff;
        transform: translateY(-2px);
    }
    
    .mmgr-tabs {
        display: flex;
        background: #f0f0f0;
        border-bottom: 2px solid #ddd;
    }
    
    .mmgr-tab {
